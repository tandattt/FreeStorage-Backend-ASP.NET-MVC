@{
    var titlePart = ViewData["Title"] as string;
    var fullTitle = string.IsNullOrEmpty(titlePart) ? "Storage Free" : $"{titlePart} — Storage Free";
    var metaDesc = ViewData["Description"] as string;
    var canonical = ViewData["Canonical"] as string;
    var robots = ViewData["Robots"] as string;
    var jsonLd = ViewData["JsonLd"] as string;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@fullTitle</title>
    @if (!string.IsNullOrEmpty(metaDesc))
    {
        <meta name="description" content="@metaDesc" />
    }
    @if (!string.IsNullOrEmpty(canonical))
    {
        <link rel="canonical" href="@canonical" />
    }
    @if (!string.IsNullOrEmpty(robots))
    {
        <meta name="robots" content="@robots" />
    }
    <meta property="og:title" content="@fullTitle" />
    @if (!string.IsNullOrEmpty(metaDesc))
    {
        <meta property="og:description" content="@metaDesc" />
    }
    <meta property="og:type" content="website" />
    @if (!string.IsNullOrEmpty(canonical))
    {
        <meta property="og:url" content="@canonical" />
    }
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="@fullTitle" />
    @if (!string.IsNullOrEmpty(metaDesc))
    {
        <meta name="twitter:description" content="@metaDesc" />
    }
    @if (!string.IsNullOrEmpty(jsonLd))
    {
        <script type="application/ld+json">@Html.Raw(jsonLd)</script>
    }
    <link rel="icon" type="image/png" sizes="32x32" href="~/favicon-32x32.png" asp-append-version="true" />
    <link rel="icon" type="image/png" href="~/favicon.png" asp-append-version="true" />
    <link rel="apple-touch-icon" href="~/apple-touch-icon.png" asp-append-version="true" />
    <script type="importmap"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Manrope:wght@700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ImageUploadApp.styles.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100 theme-editorial">
    <header>
        <nav class="navbar navbar-expand-md navbar-light navbar-editorial sticky-top">
            <div class="container-fluid px-3 px-lg-4 main-shell editorial-shell">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Storage Free</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
                        aria-controls="mainNav" aria-expanded="false" aria-label="Mở menu">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav me-auto mb-2 mb-md-0 gap-md-1 align-items-md-center">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Trang chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.RouteUrl("pricing")">Bảng giá</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.RouteUrl("developerAlbumApi")">API</a>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Photos" asp-action="Index">Ảnh của tôi</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Photos" asp-action="Upload">Tải ảnh</a>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="devMenu" role="button" data-bs-toggle="dropdown" aria-expanded="false">Developer</a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="devMenu">
                                    <li><a class="dropdown-item" href="@Url.RouteUrl("developerAlbumApi")">Tài liệu API</a></li>
                                    <li><a class="dropdown-item" href="@Url.RouteUrl("developerApiKeys")">Khóa API</a></li>
                                </ul>
                            </li>
                        }
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    <div class="container-fluid flex-grow-1 px-3 px-lg-4 py-4 py-md-5 main-shell editorial-shell mx-auto">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="app-footer app-footer--editorial mt-auto py-5">
        <div class="container-fluid px-3 px-lg-4 main-shell editorial-shell mx-auto">
            <div class="row gy-4">
                <div class="col-lg-6 text-center text-lg-start">
                    <div class="footer-brand mb-2">Storage Free</div>
                    <p class="small text-secondary mb-2">
                        Nền tảng cloud lưu trữ free giúp bạn lưu ảnh miễn phí, quản lý album online và chia sẻ quy trình tích hợp API cho developer.
                    </p>
                    <p class="small text-secondary mb-0">
                        Giải pháp host ảnh miễn phí, truy cập nhanh trên điện thoại và máy tính.
                    </p>
                </div>
                <div class="col-lg-3 text-center text-lg-start">
                    <div class="small fw-semibold mb-2">Liên kết chính</div>
                    <ul class="list-unstyled small mb-0">
                        <li><a class="link-secondary" asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                        <li><a class="link-secondary" href="@Url.RouteUrl("pricing")">Bảng giá</a></li>
                        <li><a class="link-secondary" href="@Url.RouteUrl("developerAlbumApi")">API Docs</a></li>
                        <li><a class="link-secondary" href="@Url.RouteUrl("privacy")">Chính sách quyền riêng tư</a></li>
                    </ul>
                </div>
                <div class="col-lg-3 text-center text-lg-end small text-secondary">
                    <div>&copy; @DateTime.UtcNow.Year — Storage Free</div>
                    <div class="mt-2"><a class="link-secondary" href="/sitemap.xml">Sitemap XML</a></div>
                    <div><a class="link-secondary" href="/robots.txt">Robots.txt</a></div>
                </div>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
