@model PhotosIndexVm
@{
    var from = Model.TotalCount == 0 ? 0 : (Model.Page - 1) * Model.PageSize + 1;
    var to = Model.TotalCount == 0 ? 0 : Math.Min(Model.Page * Model.PageSize, Model.TotalCount);
    var compactGrid = Model.Cols >= 8;
    var explorerHasItems = Model.ChildFolders.Count > 0 || Model.TotalCount > 0;
}

@if (TempData["Message"] is string msg)
{
    <div class="alert alert-success border-0 shadow-sm mb-4" style="border-radius: var(--radius-editorial);" role="alert">@msg</div>
}
@if (TempData["Error"] is string err)
{
    <div class="alert alert-danger border-0 shadow-sm mb-4" style="border-radius: var(--radius-editorial);" role="alert">@err</div>
}
<div id="photo-upload-flash-host"></div>
<div id="photo-af-store" class="d-none">@Html.AntiForgeryToken()</div>
<div id="photo-sync-root" class="d-none" data-sync-url="@Url.Action("Sync", "Photos")" data-index-url="@Url.Action("Index", "Photos")"
     data-revision="@Model.Revision" data-page="@Model.Page" data-page-size="@Model.PageSize" data-cols="@Model.Cols"
     data-folder-id="@(Model.FolderId?.ToString() ?? "")" data-parent-folder-id="@(Model.ParentFolderId?.ToString() ?? "")"></div>
<form id="photo-move-bulk-form" asp-action="MovePhotosBulk" method="post" class="d-none">
    @Html.AntiForgeryToken()
    <input type="hidden" name="imageIds" id="photo-bulk-image-ids" value="" />
    <input type="hidden" name="targetFolderId" id="photo-bulk-target-folder" value="" />
    <input type="hidden" name="returnFolderId" id="photo-bulk-return-folder" value="@(Model.FolderId?.ToString() ?? "")" />
</form>

<div class="d-flex flex-column flex-md-row align-items-md-end justify-content-md-between gap-4 mb-4">
    <div>
        <h1 class="editorial-page-title mb-2">Ảnh đã tải lên</h1>
        <p class="editorial-page-sub mb-0">
            @if (Model.FolderId.HasValue && !string.IsNullOrEmpty(Model.FolderName))
            {
                <span>Thư mục: <strong>@Model.FolderName</strong> · </span>
            }
            Quản lý và xem album riêng tư của bạn — giao diện tối giản, tập trung vào ảnh.
        </p>
    </div>
    @if (Model.FolderId.HasValue)
    {
        <a class="btn btn-primary d-inline-flex align-items-center gap-2 align-self-stretch align-self-md-auto px-4 py-2" asp-action="Upload" asp-route-folderId="@Model.FolderId">
            <span class="material-symbols-outlined" style="font-size: 1.25rem;">upload</span>
            Tải ảnh vào thư mục này
        </a>
    }
    else
    {
        <a class="btn btn-primary d-inline-flex align-items-center gap-2 align-self-stretch align-self-md-auto px-4 py-2" asp-action="Upload">
            <span class="material-symbols-outlined" style="font-size: 1.25rem;">upload</span>
            Tải ảnh mới
        </a>
    }
</div>

<section class="mb-4">
    <nav class="photo-breadcrumb mb-3" aria-label="Đường dẫn thư mục">
        <a class="photo-breadcrumb__link" asp-action="Index">Album</a>
        @foreach (var c in Model.Breadcrumb)
        {
            <span class="photo-breadcrumb__sep" aria-hidden="true">/</span>
            @if (Model.FolderId == c.Id)
            {
                <span class="photo-breadcrumb__current">@c.Name</span>
            }
            else
            {
                <a class="photo-breadcrumb__link" asp-action="Index" asp-route-folderId="@c.Id">@c.Name</a>
            }
        }
    </nav>
    <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
        @if (Model.FolderId.HasValue)
        {
            <a class="btn btn-sm btn-outline-secondary d-inline-flex align-items-center gap-1" asp-action="Index" asp-route-folderId="@Model.ParentFolderId" title="Thư mục cha">
                <span class="material-symbols-outlined" style="font-size: 1.1rem;">arrow_upward</span>
                Lên một cấp
            </a>
        }
        <span class="text-secondary small ms-md-1">@Model.TotalLibraryCount ảnh trong toàn bộ album</span>
    </div>
    <div class="d-flex justify-content-end">
        <div class="d-flex flex-column align-items-end gap-2 w-100 photo-folder-toolbar" style="max-width: 28rem;">
            <div class="d-flex flex-wrap align-items-center justify-content-end gap-2 w-100">
                <label class="visually-hidden" for="photo-folder-search">Tìm thư mục</label>
                <input type="search" id="photo-folder-search" class="form-control form-control-sm" maxlength="200" placeholder="Tìm thư mục…" autocomplete="off" inputmode="search" style="min-width: 11rem; max-width: 16rem;" />
                <button type="button" id="photo-toggle-create-folder" class="btn btn-sm btn-outline-secondary flex-shrink-0">Tạo thư mục</button>
                @if (Model.FolderId.HasValue)
                {
                    <form asp-action="DeleteFolder" method="post" class="m-0 d-inline" onsubmit="return confirm('Xóa thư mục này? Tất cả ảnh trực tiếp trong thư mục sẽ bị xóa vĩnh viễn; thư mục con được đưa lên cấp trên.');">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="folderId" value="@Model.FolderId" />
                        <button type="submit" class="btn btn-sm btn-outline-danger">Xóa thư mục này</button>
                    </form>
                }
            </div>
            <div id="photo-create-folder-box" class="photo-create-folder-panel surface-card border w-100 d-none" role="region" aria-labelledby="photo-create-folder-heading">
                <form asp-action="CreateFolder" method="post" class="p-3 m-0">
                    @Html.AntiForgeryToken()
                    @if (Model.FolderId.HasValue)
                    {
                        <input type="hidden" name="parentFolderId" value="@Model.FolderId" />
                    }
                    <p class="small fw-semibold mb-2" id="photo-create-folder-heading">Thư mục mới</p>
                    <label class="form-label small mb-1" for="new-folder-name">Tên thư mục</label>
                    <input name="name" id="new-folder-name" class="form-control form-control-sm mb-3" maxlength="200" placeholder="Nhập tên thư mục" autocomplete="off" />
                    <div class="d-flex flex-wrap gap-2 justify-content-end">
                        <button type="button" class="btn btn-sm btn-outline-secondary" id="photo-cancel-create-folder">Hủy</button>
                        <button type="submit" class="btn btn-sm btn-primary">Tạo</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

<section class="editorial-filters">
    <div class="storage-quota storage-quota-inline @(explorerHasItems ? "mb-3 mb-lg-4" : "mb-0")" role="region" aria-label="Dung lượng album">
        <div class="d-flex flex-wrap justify-content-between align-items-baseline gap-2 mb-2">
            <span class="editorial-label d-block mb-0">Dung lượng album</span>
            <span class="storage-quota-inline-value fw-semibold" style="color: var(--ed-primary);">
                <span class="storage-used-label" id="photo-storage-used">@Model.UsedSizeLabel</span><span class="text-secondary fw-normal"> / 5 GB</span>
            </span>
        </div>
        <div class="progress storage-quota-progress mb-0" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="@Model.QuotaPercent" aria-label="Đã dùng @Model.QuotaPercent phần trăm hạn mức">
            <div class="progress-bar storage-quota-bar" id="photo-quota-bar" style="width: @Model.QuotaPercent%"></div>
        </div>
    </div>
@if (Model.TotalCount > 0)
{
        <div id="photo-filters-row" class="d-flex flex-column flex-lg-row flex-wrap align-items-lg-end justify-content-lg-between gap-3 gap-lg-4">
            <form method="get" class="d-flex flex-wrap align-items-end gap-3 gap-md-4" id="photoGridPrefs">
                <input type="hidden" name="page" value="1" />
                @if (Model.FolderId.HasValue)
                {
                    <input type="hidden" name="folderId" value="@Model.FolderId" />
                }
                <input type="hidden" name="cols" id="colsVal" value="@Model.Cols" />
                <div class="d-none d-md-block">
                    <label for="colsSel" class="editorial-label d-block">Số cột (màn hình lớn)</label>
                    <select id="colsSel" class="form-select editorial-select" style="min-width: 10rem"
                            onchange="document.getElementById('colsVal').value=this.value;this.form.submit()">
                        @foreach (var c in new[] { 2, 3, 4, 6, 8, 10 })
                        {
                            if (Model.Cols == c)
                            {
                                <option value="@c" selected>@c cột</option>
                            }
                            else
                            {
                                <option value="@c">@c cột</option>
                            }
                        }
                    </select>
                </div>
                <div>
                    <label for="pageSizeSel" class="editorial-label d-block">Ảnh mỗi trang</label>
                    <select id="pageSizeSel" name="pageSize" class="form-select editorial-select" style="min-width: 10rem" onchange="this.form.submit()">
                        @foreach (var s in new[] { 6, 12, 24, 48 })
                        {
                            if (Model.PageSize == s)
                            {
                                <option value="@s" selected>@s ảnh</option>
                            }
                            else
                            {
                                <option value="@s">@s ảnh</option>
                            }
                        }
                    </select>
                </div>
            </form>
            <p class="editorial-stat mb-0" id="photo-page-stat">Hiển thị <strong>@from</strong>–<strong>@to</strong> trong <strong>@Model.TotalCount</strong> ảnh</p>
        </div>
}
</section>

@if (!explorerHasItems)
{
    <div class="empty-state surface-card p-5 text-center">
        <p class="text-secondary mb-4 mb-md-3">Chưa có thư mục con và chưa có ảnh ở cấp này.</p>
        @if (Model.FolderId.HasValue)
        {
            <a class="btn btn-primary px-4" asp-action="Upload" asp-route-folderId="@Model.FolderId">Tải ảnh vào thư mục</a>
        }
        else
        {
            <a class="btn btn-primary px-4" asp-action="Upload">Tải ảnh đầu tiên</a>
        }
    </div>
}
else
{
    @if (Model.TotalCount > 0)
    {
        <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
            <button type="button" class="btn btn-sm btn-outline-secondary" id="photo-select-all-page">Chọn tất cả (trang này)</button>
            <button type="button" class="btn btn-sm btn-link px-2" id="photo-clear-selection">Bỏ chọn</button>
            <span class="small text-secondary" id="photo-selection-hint">Giữ Ctrl và bấm ảnh để chọn nhiều · kéo vào biểu tượng thư mục</span>
        </div>
    }
    <div class="photo-grid-responsive photo-grid-responsive--library" id="photo-grid" style="--photo-cols: @Model.Cols">
        @foreach (var fo in Model.ChildFolders)
        {
            <a class="photo-folder-tile card editorial-card border-0 h-100 text-decoration-none"
               asp-action="Index" asp-route-folderId="@fo.Id"
               data-folder-drop-id="@fo.Id">
                <div class="photo-folder-tile__body d-flex flex-column align-items-center justify-content-center p-4 text-center h-100">
                    <span class="material-symbols-outlined photo-folder-tile__icon mb-2" aria-hidden="true">folder</span>
                    <span class="photo-folder-tile__name fw-semibold text-break">@fo.Name</span>
                    <span class="photo-folder-tile__meta small text-secondary mt-1">@fo.PhotoCount ảnh</span>
                </div>
            </a>
        }
        @foreach (var item in Model.Items)
        {
            <article class="card photo-card editorial-card border-0 h-100 @(compactGrid ? "photo-card-compact" : "")"
                     data-photo-id="@item.Id" data-photo-created-at="@item.CreatedAt.ToString("o")" data-photo-pending="@(item.IsPending ? "true" : "false")" data-photo-failed="@(item.IsFailed ? "true" : "false")" data-photo-compact="@(compactGrid ? "true" : "false")"
                     draggable="@(item.IsPending || item.IsFailed ? "false" : "true")">
                <div class="photo-thumb editorial-thumb position-relative @(item.IsPending || item.IsFailed ? "" : "photo-thumb--zoom")">
                    @if (!item.IsPending && !item.IsFailed)
                    {
                        <div class="photo-select-wrap position-absolute top-0 end-0 p-2 d-flex align-items-center gap-2" style="z-index: 4;">
                            <button type="button" class="btn btn-sm btn-light border shadow-sm photo-copy-url-btn p-1 d-inline-flex align-items-center justify-content-center"
                                    title="Sao chép URL ảnh"
                                    aria-label="Sao chép URL ảnh"
                                    data-copy-url="@($"{Context.Request.Scheme}://{Context.Request.Host}{(string.IsNullOrWhiteSpace(item.DownloadUrl) ? item.ProxyUrl : item.DownloadUrl)}")">
                                <span class="material-symbols-outlined" style="font-size: 1.05rem;">link</span>
                            </button>
                            <input type="checkbox" class="form-check-input photo-select-cb shadow-sm" title="Chọn ảnh" />
                        </div>
                    }
                    @if (item.IsPending)
                    {
                        <div class="photo-placeholder d-flex flex-column align-items-center justify-content-center h-100 w-100">
                            <div class="spinner-border text-primary mb-2" role="status" aria-hidden="true"></div>
                            <span class="small text-secondary">Đang tải lên…</span>
                            <span class="photo-pending-wait-note small text-secondary mt-1 text-center px-1 d-none" lang="vi">Đợi thêm 5–10 phút nhé.</span>
                        </div>
                    }
                    else if (item.IsFailed)
                    {
                        <div class="photo-placeholder photo-placeholder--failed d-flex flex-column align-items-center justify-content-center h-100 w-100 px-2 text-center">
                            <span class="material-symbols-outlined text-danger mb-1" style="font-size: 2rem;" aria-hidden="true">error</span>
                            <span class="small text-danger fw-semibold">Không tải được ảnh</span>
                            <span class="small text-secondary mt-1">Thử tải lên ảnh khác.</span>
                        </div>
                    }
                    else
                    {
                        <div class="position-relative w-100 h-100 photo-thumb-inner">
                            <img src="@item.ProxyUrl" alt="Ảnh đã tải" loading="lazy" decoding="async" class="photo-img" />
                            <button type="button"
                                    class="photo-zoom-open btn position-absolute top-0 start-0 w-100 h-100 p-0 border-0 bg-transparent"
                                    data-bs-toggle="modal" data-bs-target="#photoLightbox"
                                    data-img="@item.ProxyUrl" data-download="@item.DownloadUrl"
                                    aria-label="Xem ảnh phóng to"></button>
                        </div>
                    }
                </div>
                <div class="card-body photo-card__details d-none d-md-flex flex-column p-4 @(compactGrid ? "pb-2 pt-3" : "")">
                    <div class="mb-3 @(compactGrid ? "mb-0" : "")">
                        <p class="photo-meta-label">Đã tải lên</p>
                        <p class="small mb-0 photo-date" style="color: var(--ed-on-surface);">@item.CreatedAt.LocalDateTime.ToString("g")</p>
                    </div>
                    @if (!compactGrid)
                    {
                        <div class="mt-auto photo-dl-slot">
                            @if (item.IsPending)
                            {
                                <button type="button" class="btn-editorial-download" disabled style="opacity: 0.5; cursor: not-allowed;">
                                    <span class="material-symbols-outlined" style="font-size: 1.1rem;">download</span>
                                    Tải xuống
                                </button>
                            }
                            else if (item.IsFailed)
                            {
                                <button type="button" class="btn-editorial-download" disabled style="opacity: 0.5; cursor: not-allowed;">
                                    <span class="material-symbols-outlined" style="font-size: 1.1rem;">download</span>
                                    Xin lũi vì quá kém
                                </button>
                            }
                            else
                            {
                                <a class="btn-editorial-download photo-download" href="@item.DownloadUrl" download>
                                    <span class="material-symbols-outlined" style="font-size: 1.1rem;">download</span>
                                    Tải xuống
                                </a>
                            }
                        </div>
                    }
                    <form asp-action="DeleteImage" method="post" class="mt-2 mb-0" onsubmit="return confirm('Xóa ảnh này vĩnh viễn? Dung lượng album sẽ được trừ lại.');">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="imageId" value="@item.Id" />
                        @if (Model.FolderId.HasValue)
                        {
                            <input type="hidden" name="returnFolderId" value="@Model.FolderId" />
                        }
                        <button type="submit" class="btn btn-sm btn-link text-danger p-0 text-decoration-none">Xóa ảnh</button>
                    </form>
                </div>
            </article>
        }
    </div>

    <div class="modal fade photo-lightbox" id="photoLightbox" tabindex="-1" aria-labelledby="photoLightboxLabel" aria-hidden="true">
        <div class="modal-dialog photo-lightbox-dialog modal-dialog-centered modal-xl modal-fullscreen-lg-down">
            <div class="modal-content photo-lightbox-shell border-0">
                <div class="photo-lightbox-backdrop" aria-hidden="true"></div>
                <button type="button" class="photo-lightbox-close" data-bs-dismiss="modal" aria-label="Đóng">
                    <span class="material-symbols-outlined" aria-hidden="true">close</span>
                </button>
                <div class="photo-lightbox-stage">
                    <div class="photo-lightbox-zoomport" id="photoLightboxZoomport" tabindex="-1" aria-label="Khu vực ảnh — cuộn chuột hoặc chụm để zoom">
                        <img id="photoLightboxImg" src="" alt="Ảnh phóng to" class="photo-lightbox-img" draggable="false" />
                    </div>
                </div>
                <div class="photo-lightbox-chrome">
                    <p class="photo-lightbox-hint mb-0 d-md-none small text-center px-2">Chụm hai ngón để zoom · Kéo để xem khi đã phóng to · Chạm đúp ảnh để về mức ban đầu</p>
                    <p class="photo-lightbox-hint mb-0 d-none d-md-block" id="photoLightboxLabel">Cuộn chuột để zoom · Chạm đúp ảnh để về mức ban đầu</p>
                    <a id="photoLightboxDl" class="photo-lightbox-save" href="#" download>
                        <span class="material-symbols-outlined" aria-hidden="true">download</span>
                        Lưu ảnh
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div id="photo-pagination-wrap" class="@(Model.TotalPages > 1 ? "mt-5" : "d-none")">
        @if (Model.TotalPages > 1)
        {
            <nav class="d-flex justify-content-center align-items-center gap-3 gap-md-5 editorial-pagination" aria-label="Phân trang ảnh">
                <ul class="pagination mb-0 d-flex align-items-center flex-wrap justify-content-center gap-2">
                    <li class="page-item @(Model.Page <= 1 ? "disabled" : null)">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-folderId="@Model.FolderId"
                           asp-route-page="@(Model.Page - 1)"
                           asp-route-pageSize="@Model.PageSize"
                           asp-route-cols="@Model.Cols"
                           tabindex="@(Model.Page <= 1 ? "-1" : null)">
                            <span class="material-symbols-outlined" style="font-size: 1.25rem;">chevron_left</span>
                            Trước
                        </a>
                    </li>
                    <li class="page-item disabled">
                        <span class="page-info border-0 bg-transparent">Trang @Model.Page / @Model.TotalPages</span>
                    </li>
                    <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : null)">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-folderId="@Model.FolderId"
                           asp-route-page="@(Model.Page + 1)"
                           asp-route-pageSize="@Model.PageSize"
                           asp-route-cols="@Model.Cols"
                           tabindex="@(Model.Page >= Model.TotalPages ? "-1" : null)">
                            Sau
                            <span class="material-symbols-outlined" style="font-size: 1.25rem;">chevron_right</span>
                        </a>
                    </li>
                </ul>
            </nav>
        }
    </div>
}

@section Scripts {
    <script>
        (function () {
            var host = document.getElementById('photo-upload-flash-host');
            if (!host) return;

            function showFlash(text) {
                if (!text) return;
                host.innerHTML = '';
                var d = document.createElement('div');
                d.className = 'alert alert-success border-0 shadow-sm mb-4';
                d.style.borderRadius = 'var(--radius-editorial)';
                d.setAttribute('role', 'alert');
                d.textContent = text;
                host.appendChild(d);
            }

            function tryConsume() {
                try {
                    var raw = localStorage.getItem('photoUploadFlash');
                    if (!raw) return;
                    localStorage.removeItem('photoUploadFlash');
                    var o = JSON.parse(raw);
                    if (o && o.message) showFlash(o.message);
                } catch (e) { /* ignore */ }
            }

            tryConsume();
            window.addEventListener('storage', function (e) {
                if (e.key !== 'photoUploadFlash' || !e.newValue) return;
                try {
                    var o = JSON.parse(e.newValue);
                    if (o && o.message) showFlash(o.message);
                    localStorage.removeItem('photoUploadFlash');
                } catch (err) { /* ignore */ }
            });
        })();
    </script>
    <script>
        (function () {
            var search = document.getElementById('photo-folder-search');
            var toggler = document.getElementById('photo-toggle-create-folder');
            var panel = document.getElementById('photo-create-folder-box');
            var cancel = document.getElementById('photo-cancel-create-folder');
            function applyFolderSearch() {
                var grid = document.getElementById('photo-grid');
                if (!grid) return;
                var q = (search && search.value || '').trim().toLowerCase();
                grid.querySelectorAll('.photo-folder-tile').forEach(function (tile) {
                    var nm = tile.querySelector('.photo-folder-tile__name');
                    var t = nm ? nm.textContent.replace(/\s+/g, ' ').trim().toLowerCase() : '';
                    var show = !q || t.indexOf(q) !== -1;
                    tile.classList.toggle('d-none', !show);
                });
            }
            function closeCreatePanel() {
                if (panel) panel.classList.add('d-none');
            }
            if (search) search.addEventListener('input', applyFolderSearch);
            if (toggler && panel) {
                toggler.addEventListener('click', function () {
                    panel.classList.toggle('d-none');
                    if (!panel.classList.contains('d-none')) {
                        var inp = document.getElementById('new-folder-name');
                        if (inp) { inp.focus(); try { inp.select(); } catch (e) { /* ignore */ } }
                    }
                });
            }
            if (cancel && panel) cancel.addEventListener('click', closeCreatePanel);
            window.photoApplyFolderSearch = applyFolderSearch;
        })();
    </script>
    @if (Model.TotalCount > 0)
    {
        <script>
            (function () {
                const modalEl = document.getElementById('photoLightbox');
                if (!modalEl || typeof bootstrap === 'undefined') return;
                const mobileMq = window.matchMedia('(max-width: 767.98px)');

                async function shareImageToDevice(url) {
                    if (!url || !navigator.share) return false;

                    const res = await fetch(url, {
                        credentials: 'same-origin'
                    });
                    if (!res.ok) throw new Error('Khong tai duoc anh de chia se.');

                    const blob = await res.blob();
                    const contentType = blob.type || 'image/jpeg';
                    let extension = '.jpg';
                    if (contentType === 'image/png') extension = '.png';
                    else if (contentType === 'image/webp') extension = '.webp';
                    else if (contentType === 'image/gif') extension = '.gif';

                    const file = new File([blob], 'storage-free' + extension, { type: contentType });
                    if (navigator.canShare && !navigator.canShare({ files: [file] })) return false;

                    await navigator.share({
                        title: 'Anh',
                        files: [file]
                    });
                    return true;
                }

                const lightboxAction = document.getElementById('photoLightboxDl');
                if (lightboxAction) {
                    lightboxAction.addEventListener('click', async function (e) {
                        if (!mobileMq.matches) return;
                        const href = lightboxAction.getAttribute('href') || '';
                        if (!href) return;

                        e.preventDefault();
                        try {
                            const shared = await shareImageToDevice(href);
                            if (shared) return;
                        } catch (err) {
                            if (err && err.name === 'AbortError') return;
                        }

                        window.open(href, '_blank', 'noopener');
                    });
                }

                modalEl.addEventListener('show.bs.modal', function (e) {
                    const t = e.relatedTarget;
                    if (!t || !t.classList.contains('photo-zoom-open')) return;
                    const src = t.getAttribute('data-img') || '';
                    const dl = t.getAttribute('data-download') || src;
                    const img = document.getElementById('photoLightboxImg');
                    const a = document.getElementById('photoLightboxDl');
                    if (img) img.src = src;
                    if (a) {
                        a.href = mobileMq.matches ? src : dl;
                        if (mobileMq.matches) {
                            a.removeAttribute('download');
                        } else {
                            a.setAttribute('download', '');
                        }
                    }
                });
                modalEl.addEventListener('hidden.bs.modal', function () {
                    const img = document.getElementById('photoLightboxImg');
                    if (img) img.removeAttribute('src');
                });
            })();
        </script>
    }
    @if (explorerHasItems)
    {
    <script>
        (function () {
            var root = document.getElementById('photo-sync-root');
            if (!root) return;
            var syncUrl = root.getAttribute('data-sync-url');
            var indexUrl = root.getAttribute('data-index-url') || '';
            var pollMs = 5000;

            function escAttr(s) {
                if (s == null || s === '') return '';
                return String(s).replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;');
            }

            var pendingSlowNoteAfterMs = 3 * 60 * 1000;

            function updatePendingSlowNotes() {
                document.querySelectorAll('.photo-card[data-photo-pending="true"]').forEach(function (card) {
                    var iso = card.getAttribute('data-photo-created-at');
                    var note = card.querySelector('.photo-pending-wait-note');
                    if (!note) return;
                    if (!iso) {
                        note.classList.add('d-none');
                        return;
                    }
                    var t = Date.parse(iso);
                    if (isNaN(t)) {
                        note.classList.add('d-none');
                        return;
                    }
                    if (Date.now() - t > pendingSlowNoteAfterMs) {
                        note.classList.remove('d-none');
                    } else {
                        note.classList.add('d-none');
                    }
                });
            }

            function buildPaginationNav(d) {
                if (d.totalPages <= 1) return '';
                var q = function (page) {
                    var fid = d.folderId != null && d.folderId !== '' ? ('&folderId=' + encodeURIComponent(String(d.folderId))) : '';
                    return indexUrl + '?page=' + page + '&pageSize=' + encodeURIComponent(String(d.pageSize)) + '&cols=' + encodeURIComponent(String(d.cols)) + fid;
                };
                var prevDis = d.page <= 1 ? ' disabled' : '';
                var nextDis = d.page >= d.totalPages ? ' disabled' : '';
                var prevTab = d.page <= 1 ? ' tabindex="-1"' : '';
                var nextTab = d.page >= d.totalPages ? ' tabindex="-1"' : '';
                return '<nav class="d-flex justify-content-center align-items-center gap-3 gap-md-5 editorial-pagination" aria-label="Phân trang ảnh">' +
                    '<ul class="pagination mb-0 d-flex align-items-center flex-wrap justify-content-center gap-2">' +
                    '<li class="page-item' + prevDis + '"><a class="page-link" href="' + escAttr(q(d.page - 1)) + '"' + prevTab + '>' +
                    '<span class="material-symbols-outlined" style="font-size: 1.25rem;">chevron_left</span> Trước</a></li>' +
                    '<li class="page-item disabled"><span class="page-info border-0 bg-transparent">Trang ' + d.page + ' / ' + d.totalPages + '</span></li>' +
                    '<li class="page-item' + nextDis + '"><a class="page-link" href="' + escAttr(q(d.page + 1)) + '"' + nextTab + '>Sau ' +
                    '<span class="material-symbols-outlined" style="font-size: 1.25rem;">chevron_right</span></a></li></ul></nav>';
            }

            function getAfToken() {
                var st = document.getElementById('photo-af-store');
                if (!st) return '';
                var inp = st.querySelector('input[name="__RequestVerificationToken"]');
                return inp ? inp.value : '';
            }

            function buildDeleteFormHtml(idStr, viewFolderId) {
                var tok = getAfToken();
                if (!tok) return '';
                var rf = (viewFolderId != null && viewFolderId !== '') ?
                    '<input type="hidden" name="returnFolderId" value="' + escAttr(String(viewFolderId)) + '" />' : '';
                return '<form action="/Photos/DeleteImage" method="post" class="mt-2 mb-0" onsubmit="return confirm(\'Xóa ảnh này vĩnh viễn? Dung lượng album sẽ được trừ lại.\');">' +
                    '<input type="hidden" name="__RequestVerificationToken" value="' + escAttr(tok) + '" />' +
                    '<input type="hidden" name="imageId" value="' + escAttr(idStr) + '" />' + rf +
                    '<button type="submit" class="btn btn-sm btn-link text-danger p-0 text-decoration-none">Xóa ảnh</button></form>';
            }

            function buildFolderTileHtml(f) {
                var id = String(f.id != null ? f.id : f.Id);
                var name = String(f.name != null ? f.name : f.Name);
                var cnt = f.photoCount != null ? f.photoCount : (f.PhotoCount != null ? f.PhotoCount : 0);
                var href = indexUrl + (indexUrl.indexOf('?') >= 0 ? '&' : '?') + 'folderId=' + encodeURIComponent(id);
                return '<a class="photo-folder-tile card editorial-card border-0 h-100 text-decoration-none" href="' + escAttr(href) + '" data-folder-drop-id="' + escAttr(id) + '">' +
                    '<div class="photo-folder-tile__body d-flex flex-column align-items-center justify-content-center p-4 text-center h-100">' +
                    '<span class="material-symbols-outlined photo-folder-tile__icon mb-2" aria-hidden="true">folder</span>' +
                    '<span class="photo-folder-tile__name fw-semibold text-break">' + escAttr(name) + '</span>' +
                    '<span class="photo-folder-tile__meta small text-secondary mt-1">' + escAttr(String(cnt)) + ' ảnh</span></div></a>';
            }

            function buildCardHtml(item, compactGrid, viewFolderId) {
                var idStr = String(item.id != null ? item.id : item.Id);
                var compact = compactGrid ? ' photo-card-compact' : '';
                var thumbClass = 'photo-thumb editorial-thumb position-relative';
                var zoomOrNot = (item.isPending || item.isFailed) ? '' : ' photo-thumb--zoom';
                var thumbInner = '';
                if (item.isPending) {
                    thumbInner = '<div class="photo-placeholder d-flex flex-column align-items-center justify-content-center h-100 w-100">' +
                        '<div class="spinner-border text-primary mb-2" role="status" aria-hidden="true"></div>' +
                        '<span class="small text-secondary">Đang tải lên…</span>' +
                        '<span class="photo-pending-wait-note small text-secondary mt-1 text-center px-1 d-none" lang="vi">Đợi thêm 5–10 phút nhé.</span></div>';
                } else if (item.isFailed) {
                    thumbInner = '<div class="photo-placeholder photo-placeholder--failed d-flex flex-column align-items-center justify-content-center h-100 w-100 px-2 text-center">' +
                        '<span class="material-symbols-outlined text-danger mb-1" style="font-size: 2rem;" aria-hidden="true">error</span>' +
                        '<span class="small text-danger fw-semibold">Không tải được ảnh</span>' +
                        '<span class="small text-secondary mt-1">Thử tải lên ảnh khác.</span></div>';
                } else {
                    var pu = escAttr(item.proxyUrl || '');
                    var du = escAttr(item.downloadUrl || item.proxyUrl || '');
                    var copyUrl = escAttr(item.downloadUrl || item.proxyUrl || '');
                    var selBox = '<div class="photo-select-wrap position-absolute top-0 end-0 p-2 d-flex align-items-center gap-2" style="z-index: 4;">' +
                        '<button type="button" class="btn btn-sm btn-light border shadow-sm photo-copy-url-btn p-1 d-inline-flex align-items-center justify-content-center" title="Sao chép URL ảnh" aria-label="Sao chép URL ảnh" data-copy-url="' + (copyUrl && /^https?:\/\//i.test(copyUrl) ? copyUrl : (window.location.origin + copyUrl)) + '">' +
                        '<span class="material-symbols-outlined" style="font-size: 1.05rem;">link</span></button>' +
                        '<input type="checkbox" class="form-check-input photo-select-cb shadow-sm" title="Chọn ảnh" /></div>';
                    thumbInner = selBox + '<div class="position-relative w-100 h-100 photo-thumb-inner">' +
                        '<img src="' + pu + '" alt="Ảnh đã tải" loading="lazy" decoding="async" class="photo-img" />' +
                        '<button type="button" class="photo-zoom-open btn position-absolute top-0 start-0 w-100 h-100 p-0 border-0 bg-transparent" data-bs-toggle="modal" data-bs-target="#photoLightbox" data-img="' + pu + '" data-download="' + du + '" aria-label="Xem ảnh phóng to"></button></div>';
                }
                var dlPart = '';
                if (!compactGrid) {
                    if (item.isPending) {
                        dlPart = '<div class="mt-auto photo-dl-slot"><button type="button" class="btn-editorial-download" disabled style="opacity: 0.5; cursor: not-allowed;">' +
                            '<span class="material-symbols-outlined" style="font-size: 1.1rem;">download</span> Tải xuống</button></div>';
                    } else if (item.isFailed) {
                        dlPart = '<div class="mt-auto photo-dl-slot"><button type="button" class="btn-editorial-download" disabled style="opacity: 0.5; cursor: not-allowed;">' +
                            '<span class="material-symbols-outlined" style="font-size: 1.1rem;">download</span> Không có file</button></div>';
                    } else {
                        var href = escAttr(item.downloadUrl || item.proxyUrl || '');
                        dlPart = '<div class="mt-auto photo-dl-slot"><a class="btn-editorial-download photo-download" href="' + href + '" download>' +
                            '<span class="material-symbols-outlined" style="font-size: 1.1rem;">download</span> Tải xuống</a></div>';
                    }
                }
                var dateLabel = item.dateLabel || '';
                var mb = compactGrid ? ' mb-0' : '';
                var pb = compactGrid ? ' pb-2 pt-3' : '';
                var createdIso = item.createdAt != null ? String(item.createdAt) : '';
                var drag = (item.isPending || item.isFailed) ? 'false' : 'true';
                var delForm = buildDeleteFormHtml(idStr, viewFolderId);
                return '<article class="card photo-card editorial-card border-0 h-100' + compact + '" draggable="' + drag + '" data-photo-id="' + escAttr(idStr) + '" data-photo-created-at="' + escAttr(createdIso) + '" data-photo-pending="' + (item.isPending ? 'true' : 'false') + '" data-photo-failed="' + (item.isFailed ? 'true' : 'false') + '" data-photo-compact="' + (compactGrid ? 'true' : 'false') + '">' +
                    '<div class="' + thumbClass + zoomOrNot + '">' + thumbInner + '</div>' +
                    '<div class="card-body photo-card__details d-none d-md-flex flex-column p-4' + pb + '">' +
                    '<div class="mb-3' + mb + '"><p class="photo-meta-label">Đã tải lên</p><p class="small mb-0 photo-date" style="color: var(--ed-on-surface);">' + escAttr(dateLabel) + '</p></div>' +
                    (!compactGrid ? dlPart : '') + delForm + '</div></article>';
            }

            function ensurePhotoExplorerDelegate() {
                var grid = document.getElementById('photo-grid');
                if (!grid || grid._deleg) return;
                grid._deleg = true;
                var bulkForm = document.getElementById('photo-move-bulk-form');
                var r = document.getElementById('photo-sync-root');
                var lastDropTile = null;
                grid.addEventListener('change', function (e) {
                    var t = e.target;
                    if (!t || !t.classList || !t.classList.contains('photo-select-cb')) return;
                    var card = t.closest('.photo-card');
                    if (card) card.classList.toggle('photo-card--selected', t.checked);
                });
                grid.addEventListener('click', function (e) {
                    var copyBtn = e.target.closest('.photo-copy-url-btn');
                    if (copyBtn && grid.contains(copyBtn)) {
                        e.preventDefault();
                        e.stopPropagation();
                        var url = copyBtn.getAttribute('data-copy-url') || '';
                        if (!url || !navigator.clipboard || !navigator.clipboard.writeText) return;
                        navigator.clipboard.writeText(url).then(function () {
                            var icon = copyBtn.querySelector('.material-symbols-outlined');
                            if (!icon) return;
                            var old = icon.textContent;
                            icon.textContent = 'check';
                            window.setTimeout(function () {
                                icon.textContent = old || 'link';
                            }, 1200);
                        }).catch(function () { });
                        return;
                    }
                });
                grid.addEventListener('click', function (e) {
                    var card = e.target.closest('.photo-card');
                    if (!card || !grid.contains(card)) return;
                    if (e.target.closest('.photo-zoom-open') || e.target.closest('a') || e.target.closest('select') || e.target.closest('button')) return;
                    if (e.target.closest('input') && e.target.classList.contains('photo-select-cb')) return;
                    if (!e.ctrlKey && !e.metaKey) return;
                    e.preventDefault();
                    var cbx = card.querySelector('.photo-select-cb');
                    if (!cbx) return;
                    cbx.checked = !cbx.checked;
                    card.classList.toggle('photo-card--selected', cbx.checked);
                });
                grid.addEventListener('dragstart', function (e) {
                    var card = e.target.closest('.photo-card');
                    if (!card || !grid.contains(card)) return;
                    var id = card.getAttribute('data-photo-id');
                    var ids = [];
                    if (card.classList.contains('photo-card--selected')) {
                        grid.querySelectorAll('.photo-card--selected').forEach(function (c) {
                            var pid = c.getAttribute('data-photo-id');
                            if (pid) ids.push(pid);
                        });
                    } else if (id) ids = [id];
                    e.dataTransfer.setData('text/plain', ids.join(','));
                    e.dataTransfer.effectAllowed = 'move';
                }, true);
                grid.addEventListener('dragover', function (e) {
                    var tile = e.target.closest('.photo-folder-tile');
                    if (!tile || !grid.contains(tile)) {
                        if (lastDropTile) {
                            lastDropTile.classList.remove('photo-folder-tile--drop');
                            lastDropTile = null;
                        }
                        return;
                    }
                    e.preventDefault();
                    e.dataTransfer.dropEffect = 'move';
                    if (lastDropTile && lastDropTile !== tile) lastDropTile.classList.remove('photo-folder-tile--drop');
                    lastDropTile = tile;
                    tile.classList.add('photo-folder-tile--drop');
                });
                grid.addEventListener('dragleave', function (e) {
                    var tile = e.target.closest('.photo-folder-tile');
                    if (!tile || tile.contains(e.relatedTarget)) return;
                    tile.classList.remove('photo-folder-tile--drop');
                    if (lastDropTile === tile) lastDropTile = null;
                });
                grid.addEventListener('drop', function (e) {
                    var tile = e.target.closest('.photo-folder-tile');
                    if (!tile || !grid.contains(tile)) return;
                    e.preventDefault();
                    tile.classList.remove('photo-folder-tile--drop');
                    if (lastDropTile === tile) lastDropTile = null;
                    var raw = e.dataTransfer.getData('text/plain') || '';
                    var fid = tile.getAttribute('data-folder-drop-id');
                    if (!raw || !fid || !bulkForm) return;
                    var idsEl = document.getElementById('photo-bulk-image-ids');
                    var tgtEl = document.getElementById('photo-bulk-target-folder');
                    var retEl = document.getElementById('photo-bulk-return-folder');
                    if (idsEl) idsEl.value = raw;
                    if (tgtEl) tgtEl.value = fid;
                    if (retEl && r) retEl.value = r.getAttribute('data-folder-id') || '';
                    bulkForm.submit();
                });
            }

            var allBtn = document.getElementById('photo-select-all-page');
            if (allBtn && !allBtn._photoBound) {
                allBtn._photoBound = true;
                allBtn.addEventListener('click', function () {
                    document.querySelectorAll('#photo-grid .photo-select-cb').forEach(function (cb) {
                        cb.checked = true;
                        var card = cb.closest('.photo-card');
                        if (card) card.classList.add('photo-card--selected');
                    });
                });
            }
            var clearBtn = document.getElementById('photo-clear-selection');
            if (clearBtn && !clearBtn._photoBound) {
                clearBtn._photoBound = true;
                clearBtn.addEventListener('click', function () {
                    document.querySelectorAll('#photo-grid .photo-select-cb').forEach(function (cb) {
                        cb.checked = false;
                        var card = cb.closest('.photo-card');
                        if (card) card.classList.remove('photo-card--selected');
                    });
                });
            }

            async function poll() {
                var revision = root.getAttribute('data-revision') || '';
                var page = root.getAttribute('data-page') || '1';
                var pageSize = root.getAttribute('data-page-size') || '12';
                var cols = root.getAttribute('data-cols') || '6';
                var folderAttr = root.getAttribute('data-folder-id') || '';
                var folderQ = folderAttr !== '' ? ('&folderId=' + encodeURIComponent(folderAttr)) : '';
                var url = syncUrl + '?page=' + encodeURIComponent(page) + '&pageSize=' + encodeURIComponent(pageSize) + '&cols=' + encodeURIComponent(cols) + folderQ + '&revision=' + encodeURIComponent(revision);
                try {
                    var res = await fetch(url, { credentials: 'same-origin', headers: { 'Accept': 'application/json' } });
                    if (!res.ok) return;
                    var data = await res.json();
                    if (!data.changed) {
                        if (data.revision) root.setAttribute('data-revision', data.revision);
                        return;
                    }

                    var hadGrid = !!document.getElementById('photo-grid');
                    var cfs = data.childFolders || [];
                    var hasExplorer = (cfs.length > 0) || (data.totalCount || 0) > 0;
                    if (hadGrid !== hasExplorer) {
                        window.location.reload();
                        return;
                    }

                    var used = document.getElementById('photo-storage-used');
                    if (used) used.textContent = data.usedSizeLabel || '';
                    var bar = document.getElementById('photo-quota-bar');
                    var prog = document.querySelector('.storage-quota-progress');
                    var qp = typeof data.quotaPercent === 'number' ? data.quotaPercent : 0;
                    if (bar) bar.style.width = qp + '%';
                    if (prog) {
                        prog.setAttribute('aria-valuenow', String(qp));
                        prog.setAttribute('aria-label', 'Đã dùng ' + qp + ' phần trăm hạn mức');
                    }

                    var stat = document.getElementById('photo-page-stat');
                    if (stat) {
                        stat.innerHTML = 'Hiển thị <strong>' + data.from + '</strong>–<strong>' + data.to + '</strong> trong <strong>' + data.totalCount + '</strong> ảnh';
                    }

                    var grid = document.getElementById('photo-grid');
                    if (grid) {
                        grid.style.setProperty('--photo-cols', String(data.cols));
                        var items = data.items || [];
                        var cg = !!data.compactGrid;
                        var folderHtml = (data.childFolders || []).map(buildFolderTileHtml).join('');
                        var vf = data.folderId != null && data.folderId !== undefined && data.folderId !== '' ? String(data.folderId) : '';
                        var photoHtml = items.map(function (it) { return buildCardHtml(it, cg, vf); }).join('');
                        grid.innerHTML = folderHtml + photoHtml;
                        updatePendingSlowNotes();
                        if (typeof window.photoApplyFolderSearch === 'function') window.photoApplyFolderSearch();
                    }

                    var wrap = document.getElementById('photo-pagination-wrap');
                    if (wrap) {
                        if (data.totalPages > 1) {
                            wrap.className = 'mt-5';
                            wrap.innerHTML = buildPaginationNav(data);
                        } else {
                            wrap.className = 'd-none';
                            wrap.innerHTML = '';
                        }
                    }

                    root.setAttribute('data-revision', data.revision || '');
                    root.setAttribute('data-page', String(data.page));
                    root.setAttribute('data-page-size', String(data.pageSize));
                    root.setAttribute('data-cols', String(data.cols));
                    if (data.folderId != null && data.folderId !== undefined && data.folderId !== '') {
                        root.setAttribute('data-folder-id', String(data.folderId));
                    } else {
                        root.setAttribute('data-folder-id', '');
                    }
                    if (data.parentFolderId != null && data.parentFolderId !== undefined && data.parentFolderId !== '') {
                        root.setAttribute('data-parent-folder-id', String(data.parentFolderId));
                    } else {
                        root.setAttribute('data-parent-folder-id', '');
                    }
                    var retEl = document.getElementById('photo-bulk-return-folder');
                    if (retEl) retEl.value = root.getAttribute('data-folder-id') || '';
                } catch (_) { /* giữ interval */ }
            }

            setInterval(poll, pollMs);
            updatePendingSlowNotes();
            setInterval(updatePendingSlowNotes, 30000);
            ensurePhotoExplorerDelegate();
        })();
    </script>
    }
}
